        let currentStationIndex = 0;
        let isSpeaking = false;
        let synth = window.speechSynthesis;
        let speechUtterance = null;

        // 2. Control Audio Guide Overlay Toggle
        function toggleAudioGuideIntro() {
            const intro = document.getElementById('audioIntro');
            intro.classList.toggle('hidden');
            if(!intro.classList.contains('hidden')){
                intro.classList.add('fade-in');
            }
        }

        // 3. Switch Station Feature
        function switchStation(index) {
            currentStationIndex = index;
            const data = stationsData[index];
            
            // Stop speech if switching station
            if (isSpeaking) {
                stopSpeech();
            }

            // Update Map Buttons Active Styling
            document.querySelectorAll('.map-btn').forEach((btn, idx) => {
                if (idx === index) {
                    btn.className = "map-btn p-3 bg-emerald-50 border-2 border-emerald-600 rounded-lg text-left transition-all";
                    const titleDiv = btn.querySelector('div:nth-child(2)');
                    if(titleDiv) titleDiv.className = "text-sm font-bold text-emerald-900";
                } else {
                    btn.className = "map-btn p-3 bg-stone-50 border border-stone-200 rounded-lg text-left transition-all hover:bg-stone-100";
                    const titleDiv = btn.querySelector('div:nth-child(2)');
                    if(titleDiv) titleDiv.className = "text-sm font-semibold text-stone-800";
                }
            });

            // Update Card Contents with smooth flash animation
            const card = document.getElementById('station-card');
            card.style.opacity = '0.3';
            
            setTimeout(() => {
                document.getElementById('station-accent').className = `h-3 ${data.accent}`;
                document.getElementById('station-tag').innerText = data.tag;
                document.getElementById('station-tag').className = `font-bold text-xs tracking-wider uppercase font-prompt text-emerald-800`;
                document.getElementById('station-title').innerText = data.title;
                document.getElementById('station-quote').innerText = data.quote;
                document.getElementById('station-desc').innerText = data.desc;
                document.getElementById('station-tips').innerText = data.tips;
                document.getElementById('ai-image-preview').src = data.img;

                // Re-render Activities List
                const actList = document.getElementById('station-activities');
                actList.innerHTML = '';
                data.activities.forEach(act => {
                    const li = document.createElement('li');
                    li.innerText = act;
                    actList.appendChild(li);
                });

                // Reset AI Chat Box UI
                document.getElementById('ai-chat-output-box').classList.add('hidden');
                document.getElementById('ai-chat-text').innerText = '';
                document.getElementById('ai-custom-prompt').value = '';

                card.style.opacity = '1';
                card.classList.add('fade-in');
                setTimeout(() => card.classList.remove('fade-in'), 400);
            }, 200);
        }

        // 4. Web Speech API (AI Audio Guide Synthesizer)
        function toggleAudioPlay() {
            if (isSpeaking) {
                stopSpeech();
            } else {
                startSpeech();
            }
        }

        function startSpeech() {
            if (!synth) return alert("เบราว์เซอร์ของคุณไม่รองรับระบบเสียงบรรยาย");
            
            const textToSpeak = stationsData[currentStationIndex].ttsText;
            speechUtterance = new SpeechSynthesisUtterance(textToSpeak);
            
            // Search for Thai Voice
            const voices = synth.getVoices();
            const thaiVoice = voices.find(voice => voice.lang === 'th-TH' || voice.lang.includes('TH'));
            if (thaiVoice) {
                speechUtterance.voice = thaiVoice;
            }
            
            speechUtterance.rate = 1.0;
            speechUtterance.pitch = 1.0;

            speechUtterance.onend = () => {
                resetAudioBtn();
            };

            speechUtterance.onerror = () => {
                resetAudioBtn();
            };

            document.getElementById('audio-btn-text').innerText = "กำลังบรรยาย... (คลิกเพื่อหยุด)";
            document.getElementById('audio-icon').setAttribute('data-lucide', 'square');
            lucide.createIcons();
            
            isSpeaking = true;
            synth.speak(speechUtterance);
        }

        function stopSpeech() {
            if (synth && synth.speaking) {
                synth.cancel();
            }
            resetAudioBtn();
        }

        function resetAudioBtn() {
            isSpeaking = false;
            document.getElementById('audio-btn-text').innerText = "ฟังเสียงบรรยาย";
            document.getElementById('audio-icon').setAttribute('data-lucide', 'volume-2');
            lucide.createIcons();
        }

        // 5. AI Farm Generator Simulator (Imagen Mockup)
        function generateRealAIImage() {
            const loading = document.getElementById('ai-loading');
            loading.classList.remove('hidden');
            
            // Simulate AI render delay time
            setTimeout(() => {
                loading.classList.add('hidden');
                // Switch to a fresh related stunning landscape dynamically inside base station selection
                const randomIds = [1593113041543-ec5e10d2962d, 1500651230198-e7e24a42e77b, 1523348837484-bc4ae47d6476];
                const currentImg = stationsData[currentStationIndex].img;
                document.getElementById('ai-image-preview').src = currentImg + "&sig=" + Math.floor(Math.random() * 1000);
            }, 1800);
        }

        // 6. AI Smart Consultant Interactive Simulation
        function askAIExpert(presetPrompt) {
            const chatBox = document.getElementById('ai-chat-output-box');
            const chatText = document.getElementById('ai-chat-text');
            
            chatBox.classList.remove('hidden');
            chatText.innerText = "กำลังประมวลผลคำตอบจากปราชญ์เกษตรอัจฉริยะ...";
            
            setTimeout(() => {
                let answer = `ขอแนะนำในฐานะปราชญ์ประจำฐานนี้ครับ สำหรับหัวข้อ "${presetPrompt}" สิ่งสำคัญคือเราต้องยึดหลักการพึ่งตนเองเป็นที่ตั้ง 

1. ปรับสมดุลตามธรรมชาติ: พยายามหลีกเลี่ยงการใช้สารเคมีในทุกขั้นตอน ให้ใช้ทรัพยากรหมุนเวียนในแปลง เช่น การทำน้ำหมักจุลินทรีย์ และปุ๋ยหมักใบไม้ 
2. การดูแลรักษาที่ถูกวิธี: ควรรดน้ำในช่วงเช้าตรู่ และตรวจเช็คระบบระบายน้ำเพื่อป้องกันรากเน่าเฉาตาย
3. เคล็ดลับเพิ่มผลผลิต: แนะนำให้ประยุกต์ใช้องค์ความรู้การจัดการพื้นที่รวมร่วมกับสูตร 30:30:30:10 เพื่อให้เกิดความสมบูรณ์สูงสุดครับ`;
                
                chatText.innerText = answer;
            }, 1000);
        }

        function askAICustom() {
            const input = document.getElementById('ai-custom-prompt');
            const prompt = input.value.trim();
            if (!prompt) return alert("กรุณาพิมพ์ข้อสงสัยหรือคำถามของคุณ");
            
            askAIExpert(prompt);
            input.value = '';
        }

        // 7. Share Base Feature
        function shareStation() {
            const currentTitle = stationsData[currentStationIndex].title;
            if (navigator.share) {
                navigator.share({
                    title: currentTitle,
                    text: `ศึกษาเรียนรู้ศาสตร์พระราชาประจำฐาน: ${currentTitle} ศูนย์การเรียนรู้ มทบ.๔๓`,
                    url: window.location.href
                }).catch(console.error);
            } else {
                alert(`คัดลอกลิงก์สถานี "${currentTitle}" สำเร็จ! สามารถส่งต่อให้เพื่อนหรือคณะเข้าชมได้ทันที`);
            }
        }

        // 8. Personal Land Planner Algorithm (30:30:30:10 Rule)
        function calculatePlan() {
            const sizeInput = document.getElementById('planner-size');
            const totalSize = parseFloat(sizeInput.value);
            
            if (isNaN(totalSize) || totalSize <= 0) {
                alert("กรุณากรอกขนาดพื้นที่เป็นตัวเลขที่ถูกต้อง (ตารางวา)");
                return;
            }

            // Calculations based on standard theory rules
            const water = totalSize * 0.30;
            const rice = totalSize * 0.30;
            const garden = totalSize * 0.30;
            const home = totalSize * 0.10;

            // Update UI elements inside container
            document.getElementById('res-water').innerText = water.toLocaleString(undefined, {maximumFractionDigits: 1});
            document.getElementById('res-rice').innerText = rice.toLocaleString(undefined, {maximumFractionDigits: 1});
            document.getElementById('res-garden').innerText = garden.toLocaleString(undefined, {maximumFractionDigits: 1});
            document.getElementById('res-home').innerText = home.toLocaleString(undefined, {maximumFractionDigits: 1});

            // Contextual advice generator based on selected dropdown targets
            const goal = document.getElementById('planner-goal').value;
            let adviceText = "";
            
            if (goal === "protein") {
                adviceText = "💡 คำแนะนำจาก AI: สำหรับการเน้นปศุสัตว์ ควรขุดบ่อรอบขอบสระน้ำเพื่อเลี้ยงปลาดุกหรือปลานิล และสร้างเล้าไก่ไข่เหนือน้ำ เพื่อให้มูลไก่เป็นอาหารปลา ช่วยลดต้นทุนลงได้สูงสุด";
            } else if (goal === "mixed") {
                adviceText = "💡 คำแนะนำจาก AI: เน้นเกษตรหมุนเวียน แนะนำให้จัดแปลงพืชสวนแบ่งเป็นพืชล้มลุกอายุสั้นเพื่อบริโภครายวัน และไม้ผลยืนต้นเพื่อสร้างความมั่นคงในครัวเรือนอย่างสมดุล";
            } else if (goal === "forest") {
                adviceText = "💡 คำแนะนำจาก AI: แนะนำให้ปลูกไม้ป่าในส่วนพื้นที่ 30% ทางทิศตะวันตกเพื่อเป็นแนวกันลมและบังแดดบ่าย และใช้หลักการปลูกไม้ 3 อย่าง ได้แก่ ไม้กิน ไม้ใช้สอย และไม้เศรษฐกิจ";
            } else {
                adviceText = "💡 คำแนะนำจาก AI: เน้นสมุนไพรเชิงท่องเที่ยว แนะนำแบ่งสัดส่วนพื้นที่รอบที่อยู่อาศัยเป็นแปลงสวนครัวสมุนไพรรูปแบบสวยงามจัดระเบียบง่ายเพื่อให้คณะเข้าเยี่ยมชมศึกษาได้สะดวก";
            }
            
            document.getElementById('planner-advice').innerText = adviceText;
            
            // Show result display
            const resBox = document.getElementById('planner-result');
            resBox.classList.remove('hidden');
            resBox.classList.add('fade-in');
        }

        // Initialize Lucide Vector Icons on Startup
        window.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();
            // Trigger voice setup pre-loading inside speech synthesis engine
            if (synth && synth.onvoiceschanged !== undefined) {
                synth.onvoiceschanged = () => {};
            }
        });
    </script>
